{
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "src/**",
      "test/**",
      "scripts/**",
      "package.json",
      "tsconfig.json",
      "tsconfig.test.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
